{
  "name": "ddvh",
  "version": "0.1.0",
  "private": true,
  "description": "Ddvh - Discord voice bridge to Volcengine Doubao Omni Realtime WebSocket",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/**' build && pnpm -r --filter './apps/**' build",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "install:plugins": "bash scripts/install.sh --target both --source-dir \"$(pwd)\"",
    "install:openclaw": "bash scripts/install.sh --target openclaw --source-dir \"$(pwd)\"",
    "install:claude": "bash scripts/install.sh --target claude --source-dir \"$(pwd)\"",
    "preflight:github": "node scripts/github-preflight.mjs",
    "smoke-test": "node scripts/smoke-test.mjs",
    "clean": "pnpm -r run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "typescript": "^5.7.2",
    "prettier": "^3.4.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "vitest": "^2.1.0",
    "@vitest/coverage-v8": "^2.1.0"
  },
  "packageManager": "pnpm@9.15.0",
  "keywords": [
    "discord",
    "voice",
    "volcengine",
    "doubao",
    "omni",
    "websocket",
    "realtime"
  ],
  "author": "",
  "license": "MIT"
}
