# Discord Bot Configuration
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# Volcengine Doubao Omni Configuration
VOLCENGINE_OMNI_ENDPOINT=wss://doubao.com/v1/realtime
VOLCENGINE_OMNI_API_KEY=
VOLCENGINE_OMNI_MODEL=

# Backend Dispatcher Configuration
BACKEND_DISPATCH_ENDPOINT=http://localhost:3000/api/dispatch
BACKEND_WEBHOOK_SECRET=
BACKEND_WEBHOOK_PORT=8866

# Audio Configuration
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_FRAME_DURATION_MS=200

# Memory Bank Configuration
MEMORY_DB_PATH=./data/memory.db

# Logging Configuration
LOG_LEVEL=info
LOG_PRETTY_PRINT=true

# Plugin Configuration
OPENCLAW_PLUGIN_HOME=~/.openclaw/plugins/voice-hub
CLAUDE_MARKETPLACE_HOME=~/.claude/marketplace/voice-hub
